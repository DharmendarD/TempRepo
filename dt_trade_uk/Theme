<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    x:Class="Oasis.Mobile.Theme.likewize_trade_us"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:common="clr-namespace:Oasis.Mobile.Common.Views"
    xmlns:controls="clr-namespace:Oasis.Mobile.Core">

    <!--  Start - Common Styling Colors  -->

    <Color x:Key="Primary5">#FFE0F0</Color>
    <Color x:Key="Primary10">#FFC7E4</Color>
    <Color x:Key="Primary20">#FF97CD</Color>
    <Color x:Key="Primary100">#e20074</Color>
    <Color x:Key="Primary120">#9e0051</Color>


    <Color x:Key="Teritiary5">#d3d7f9</Color>
    <Color x:Key="Teritiary10">#AABCFD</Color>
    <Color x:Key="Teritiary20">#7D94F9</Color>
    <Color x:Key="Teritiary100">#2238df</Color>
    <Color x:Key="Teritiary120">#000d99</Color>

    <controls:LwColor x:Key="SecondaryIconColor" CloneColorKey="Neutral50" />
    <controls:LwColor x:Key="GlobalTileFrameBorderColor" CloneColorKey="White" />
    <Color x:Key="PageContentBackgroundColor">Transparent</Color>
    <controls:PopModalButtondOrder x:Key="PopModalButtondOrder">CancelAccept</controls:PopModalButtondOrder>

    <!--  End - Common Styling Colors  -->

    <!--  Start - Common Values  -->

    <OnPlatform
        x:Key="RegularFont"
        x:TypeArguments="x:String"
        Default="Likewize-Regular" />

    <OnPlatform
        x:Key="BoldFont"
        x:TypeArguments="x:String"
        Default="Likewize-Bold" />

    <OnPlatform
        x:Key="GlobalEntryHeight"
        x:TypeArguments="x:Double"
        Default="40">
        <On Platform="WinUI" Value="35" />
    </OnPlatform>

    <OnPlatform
        x:Key="GlobalButtonPadding"
        x:TypeArguments="Thickness"
        Default="20,12.5">
        <On Platform="WinUI" Value="20,15.5,20,9.5" />
    </OnPlatform>

    <OnPlatform
        x:Key="GlobalEntryPadding"
        x:TypeArguments="Thickness"
        Default="16,0">
        <On Platform="WinUI" Value="16,3,16,0" />
    </OnPlatform>

    <OnPlatform
        x:Key="GlobalSmallButtonPadding"
        x:TypeArguments="Thickness"
        Default="16,10">
        <On Platform="WinUI" Value="16,12,16,8" />
    </OnPlatform>

    <OnPlatform
        x:Key="GlobalLabelPadding"
        x:TypeArguments="Thickness"
        Default="0">
        <On Platform="WinUI" Value="0,5,0,0" />
    </OnPlatform>

    <OnPlatform
        x:Key="GlobalButtonCornerRadius"
        x:TypeArguments="x:Int32"
        Default="22" />


    <x:Int32 x:Key="GlobalTileFrameCornerRadius">8</x:Int32>

    <x:Double x:Key="LabelLineHeight">1.5</x:Double>
    <x:Double x:Key="BoldLabelLineHeight">1.2</x:Double>
    <x:Double x:Key="GlobalEntryFontSize">14</x:Double>

    <x:Boolean x:Key="GlobalTileFrameHasShadow">False</x:Boolean>
    <x:Boolean x:Key="DeviceFrameHasShadow">False</x:Boolean>

    <!--  End - Common Values  -->

    <!--  Start - Global Styles  -->

    <Style ApplyToDerivedTypes="True" TargetType="controls:LwBasePage">
        <Setter Property="StatusBarColor" Value="{DynamicResource Primary5}" />
        <Setter Property="StatusBarStyle" Value="DarkContent" />
        <Setter Property="BackgroundColor" Value="{DynamicResource PageBackgroundColor}" />
    </Style>

    <Style ApplyToDerivedTypes="True" TargetType="common:ConnectionErrorPage">
        <Setter Property="StatusBarColor" Value="{DynamicResource Primary5}" />
        <Setter Property="StatusBarStyle" Value="DarkContent" />
        <Setter Property="BackgroundColor" Value="{DynamicResource Primary5}" />
    </Style>

    <Style ApplyToDerivedTypes="True"
           TargetType="controls:InputViewWithValidation">
        <Setter Property="ErrorImageVisible" Value="True"/>
    </Style>

    <Style ApplyToDerivedTypes="True" TargetType="controls:LwLabel">
        <Setter Property="LineBreakMode" Value="WordWrap" />
        <Setter Property="FontFamily" Value="{DynamicResource RegularFont}" />
        <Setter Property="TextColor" Value="{DynamicResource GlobalFontColor}" />
        <Setter Property="FontSize" Value="{DynamicResource Medium}" />
        <Setter Property="Padding" Value="{DynamicResource GlobalLabelPadding}" />
        <Setter Property="MultilineHeight" Value="{DynamicResource LabelLineHeight}" />
        <Style.Triggers>
            <Trigger TargetType="controls:LwLabel" Property="FontFamily" Value="{StaticResource BoldFont}">
                <Setter Property="MultilineHeight" Value="{DynamicResource BoldLabelLineHeight}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  End - Global Styles  -->

    <!--  Popup Style  -->
    
    <Style x:Key="PopupModalHeaderGrid" TargetType="Grid">
        <Setter Property="Padding" Value="16" />
        <Style.Triggers>
            <Trigger TargetType="Grid" Property="BindingContext" Value="{x:Static controls:PopupModalIcon.Info}">
                <Setter Property="BackgroundColor" Value="{DynamicResource Primary5}" />
            </Trigger>

            <Trigger TargetType="Grid" Property="BindingContext" Value="{x:Static controls:PopupModalIcon.Warning}">
                <Setter Property="BackgroundColor" Value="{DynamicResource Warning5}" />
            </Trigger>

            <Trigger TargetType="Grid" Property="BindingContext" Value="{x:Static controls:PopupModalIcon.Error}">
                <Setter Property="BackgroundColor" Value="{DynamicResource Error5}" />
            </Trigger>

            <Trigger TargetType="Grid" Property="BindingContext" Value="{x:Static controls:PopupModalIcon.Success}">
                <Setter Property="BackgroundColor" Value="{DynamicResource Success5}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PopupModalHeaderLabel" TargetType="controls:LwLabel">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{DynamicResource PopupModalHeaderTextColor}" />
        <Setter Property="Padding" Value="{OnPlatform Default='0,1,0,0', iOS='0,-1,0,0', MacCatalyst=0, Android='0,-2,0,0'}" />
        <Setter Property="FontFamily" Value="{DynamicResource RegularFont}" />
        <Style.Triggers>
            <Trigger TargetType="controls:LwLabel" Property="BindingContext" Value="{x:Static controls:PopupModalIcon.Info}">
                <Setter Property="TextColor" Value="{DynamicResource Primary100}" />
            </Trigger>

            <Trigger TargetType="controls:LwLabel" Property="BindingContext" Value="{x:Static controls:PopupModalIcon.Warning}">
                <Setter Property="TextColor" Value="{DynamicResource Warning120}" />
            </Trigger>

            <Trigger TargetType="controls:LwLabel" Property="BindingContext" Value="{x:Static controls:PopupModalIcon.Error}">
                <Setter Property="TextColor" Value="{DynamicResource Error120}" />
            </Trigger>

            <Trigger TargetType="controls:LwLabel" Property="BindingContext" Value="{x:Static controls:PopupModalIcon.Success}">
                <Setter Property="TextColor" Value="{DynamicResource Success120}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PopupModalIconStyle" TargetType="controls:LwGlyph">
        <Setter Property="Margin" Value="0,0,16,0" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="VerticalOptions" Value="CenterAndExpand" />
        <Style.Triggers>
            <Trigger TargetType="controls:LwGlyph" Property="BindingContext" Value="{x:Static controls:PopupModalIcon.Info}">
                <Setter Property="GlyphType" Value="Solid" />
                <Setter Property="TextColor" Value="{DynamicResource Primary100}" />
            </Trigger>

            <Trigger TargetType="controls:LwGlyph" Property="BindingContext" Value="{x:Static controls:PopupModalIcon.Warning}">
                <Setter Property="TextColor" Value="{DynamicResource Warning100}" />
                <Setter Property="GlyphType" Value="Solid" />
            </Trigger>

            <Trigger TargetType="controls:LwGlyph" Property="BindingContext" Value="{x:Static controls:PopupModalIcon.Error}">
                <Setter Property="TextColor" Value="{DynamicResource Error100}" />
                <Setter Property="GlyphType" Value="Solid" />
            </Trigger>

            <Trigger TargetType="controls:LwGlyph" Property="BindingContext" Value="{x:Static controls:PopupModalIcon.Success}">
                <Setter Property="GlyphType" Value="Solid" />
                <Setter Property="TextColor" Value="{DynamicResource Success100}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PopupModalCloseIconStyle" TargetType="controls:LwGlyph">
        <Setter Property="Text" Value="&#xf00d;" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="VerticalOptions" Value="CenterAndExpand" />
        <Setter Property="HorizontalOptions" Value="EndAndExpand" />

        <Style.Triggers>
            <Trigger TargetType="controls:LwGlyph" Property="BindingContext" Value="{x:Static controls:PopupModalIcon.Info}">
                <Setter Property="TextColor" Value="{DynamicResource Primary100}" />
            </Trigger>

            <Trigger TargetType="controls:LwGlyph" Property="BindingContext" Value="{x:Static controls:PopupModalIcon.Warning}">
                <Setter Property="TextColor" Value="{DynamicResource Warning100}" />
            </Trigger>

            <Trigger TargetType="controls:LwGlyph" Property="BindingContext" Value="{x:Static controls:PopupModalIcon.Error}">
                <Setter Property="TextColor" Value="{DynamicResource Error100}" />
            </Trigger>

            <Trigger TargetType="controls:LwGlyph" Property="BindingContext" Value="{x:Static controls:PopupModalIcon.Success}">
                <Setter Property="TextColor" Value="{DynamicResource Success100}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  End  -->

    <!--  Start - Common Data Templates  -->

<DataTemplate x:Key="HeaderTemplate">
    <Grid
        Margin="-2,-3"
        Padding="16,12"
        BackgroundColor="{DynamicResource Primary5}"
        ColumnDefinitions="Auto,*"
        RowDefinitions="Auto"
        MinimumHeightRequest="50"
        HorizontalOptions="Fill">
        <controls:LwGlyph
            Grid.Column="0"
            FontSize="18"
            HorizontalOptions="Start"
            Text="{x:Static controls:LwGlyphHelper.ARROW_LEFT}"
            TextColor="{StaticResource Primary}"
            VerticalOptions="Center"
            IsVisible="{TemplateBinding IsBackButtonVisible}"
            ZIndex="1">
            <controls:LwGlyph.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding BackButtonCommand, Source={x:StaticResource Source}}" />
            </controls:LwGlyph.GestureRecognizers>
        </controls:LwGlyph>

        <controls:LwLabel
            Grid.Column="1"
            MinimumHeightRequest="10"
            HorizontalOptions="Center"
            Style="{controls:LwDynamicLabelStyleGenerator PrimaryMediumBold}"
            Text="{TemplateBinding Title}"
            VerticalOptions="Center" />
    </Grid>
</DataTemplate>

    <!--  End - Common Data Templates  -->

</ResourceDictionary>
